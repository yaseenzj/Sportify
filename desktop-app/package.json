{
  "name": "sportify_byzj",
  "version": "1.0.0-beta.3",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "vite",
    "build": "vite build && electron-builder -w",
    "publish-beta": "vite build && electron-builder -w -p always",
    "electron:start": "electron ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaseenzj/Sportify.git"
  },
  "keywords": [],
  "author": "ZJ Labs",
  "license": "AGPL-3.0",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/yaseenzj/Sportify/issues"
  },
  "homepage": "https://github.com/yaseenzj/Sportify#readme",
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.1.3"
  },
  "build": {
    "appId": "com.sportify.app",
    "productName": "Sportify",
    "afterPack": "./scripts/strip-locales.js",
    "directories": {
      "output": "dist"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "dist-react/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "yaseenzj",
        "repo": "Sportify"
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
